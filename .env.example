# Optional if the commodity backend repo is not discoverable as a sibling "Commodity Prices" folder.
COMMODITY_BACKEND_ROOT=/absolute/path/to/Commodity Prices

# Matches the commodity backend pipeline setting. Relative sqlite paths resolve from COMMODITY_BACKEND_ROOT.
DATABASE_URL=sqlite:///data/commodities.db

# Product server bind settings.
HOST=127.0.0.1
PORT=8080

# Optional headline feed overrides for CommodityWatch.
# COMMODITYWATCH_HEADLINE_FEED_PATH=data/feed.local.json
# COMMODITYWATCH_FEED_OUTPUT=data/feed.local.json

# Optional frontend API base for the Next.js InventoryWatch app in frontend/.
# Defaults to /api when omitted.
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api

# Optional InventoryWatch backend API base for the production CommodityWatch shell.
# Defaults to NEXT_PUBLIC_API_BASE_URL when set, otherwise http://127.0.0.1:8000/api.
# INVENTORYWATCH_API_BASE_URL=http://127.0.0.1:8000/api

# Optional published local InventoryWatch SQLite store for browse-time reads.
# Defaults to data/inventorywatch.db.
# INVENTORYWATCH_PUBLISHED_DB_PATH=data/inventorywatch.db

# Optional InventoryWatch browse-time source selection for server.py.
# auto  = use the local published archive when available, otherwise proxy the separate backend
# local = require the local published archive only
# remote = require the separate backend only
# INVENTORYWATCH_BROWSE_MODE=auto
